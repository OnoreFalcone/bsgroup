---
import BaseLayout from '@layouts/BaseLayout.astro';
import UeberUnsHero from '@components/sections/UeberUnsHero.astro';
import HistoryTimeline from '@components/sections/HistoryTimeline.astro';
import WasUnsAusmacht from '@components/sections/WasUnsAusmacht.astro';
import LeadershipTeam from '@components/sections/LeadershipTeam.astro';
import Engagement from '@components/sections/Engagement.astro';
import OfficePhotos from '@components/sections/OfficePhotos.astro';
import FinalCta from '@components/sections/FinalCta.astro';
import { withBase } from '@/utils/url';
---

<BaseLayout
  title="Über uns"
  description="30 Jahre am Schweizer Finanzplatz. Eigentümergeführt. Beraterinnen und Berater, die im Schnitt über acht Jahre bleiben."
>
  <UeberUnsHero />
  <HistoryTimeline />
  <WasUnsAusmacht />
  <LeadershipTeam />
  <Engagement />
  <OfficePhotos />
  <FinalCta
    heading="Macher gesucht."
    body="Wir wachsen, wenn die richtigen Leute kommen — nicht weil die Pipeline es will. Wenn Sie liefern statt präsentieren wollen, sollten wir reden."
    primaryLabel="Offene Stellen ansehen"
    primaryHref={withBase('/karriere')}
    secondaryLabel="Initiativbewerbung"
    secondaryHref={withBase('/karriere')}
  />
</BaseLayout>
