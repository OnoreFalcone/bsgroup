---
import { withBase } from '@/utils/url';

const columns = [
  {
    title: 'Services',
    items: [
      { label: 'Project Services', href: withBase('/services/project-services') },
      { label: 'Solution Services', href: withBase('/services/solution-services') },
      { label: 'Quality Services', href: withBase('/services/quality-services') },
      { label: 'Software Services', href: withBase('/services/software-services') },
    ],
  },
  {
    title: 'Unternehmen',
    items: [
      { label: 'Über uns', href: withBase('/ueber-uns') },
      { label: 'Karriere', href: withBase('/karriere') },
      { label: 'Insights', href: withBase('/insights') },
      { label: 'Referenzen', href: withBase('/referenzen') },
    ],
  },
  {
    title: 'Kontakt',
    items: [
      { label: 'Standort Zürich', href: withBase('/kontakt') },
      { label: 'backoffice@bsgroup.ch', href: 'mailto:backoffice@bsgroup.ch' },
      { label: 'LinkedIn', href: 'https://linkedin.com/company/bsgroup' },
    ],
  },
];

const homeHref       = withBase('/');
const impressumHref  = withBase('/impressum');
const datenschutzHref = withBase('/datenschutz');
const agbHref        = withBase('/agb');
---

<footer class="bg-bg-inverse text-fg-inverse">
  <div class="max-w-layout mx-auto px-md md:px-2xl pt-3xl pb-lg">
    <div class="flex flex-col lg:flex-row gap-2xl pb-2xl">
      <div class="lg:w-[360px] space-y-sm">
        <a href={homeHref} class="inline-block text-2xl md:text-2xl font-bold tracking-tight text-white hover:opacity-80 transition-opacity">
          Business Solution Group AG
        </a>
        <p class="text-body-m opacity-70">Aus Konzept wird Realität.</p>
      </div>
      <div class="flex-1 grid grid-cols-1 sm:grid-cols-3 gap-xl">
        {columns.map(col => (
          <div class="space-y-xs">
            <p class="text-eyebrow opacity-50">{col.title}</p>
            <ul class="space-y-2xs">
              {col.items.map(item => (
                <li>
                  <a href={item.href} class="text-body-m hover:opacity-70 transition-opacity">
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="border-t border-white/20 pt-sm flex flex-col sm:flex-row justify-between gap-md text-body-s opacity-50">
      <p>© {new Date().getFullYear()} Business Solution Group AG · Zürich</p>
      <ul class="flex gap-md">
        <li><a href={impressumHref} class="hover:opacity-70 transition-opacity">Impressum</a></li>
        <li><a href={datenschutzHref} class="hover:opacity-70 transition-opacity">Datenschutz</a></li>
        <li><a href={agbHref} class="hover:opacity-70 transition-opacity">AGB</a></li>
      </ul>
    </div>
  </div>
</footer>
