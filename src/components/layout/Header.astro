---
type NavItem = {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
};

const navItems: NavItem[] = [
  {
    label: 'Services',
    href: '/services',
    children: [
      { label: 'Übersicht',                    href: '/services' },
      { label: 'Project Services',             href: '/services/project-services' },
      { label: 'Solution Services',            href: '/services/solution-services' },
      { label: 'Quality Services',             href: '/services/quality-services' },
      { label: 'Software Services',            href: '/services/software-services' },
    ],
  },
  { label: 'Referenzen', href: '/referenzen' },
  { label: 'Insights',   href: '/insights'   },
  { label: 'Über uns',   href: '/ueber-uns'  },
  { label: 'Karriere',   href: '/karriere'   },
];
---

<header
  id="main-header"
  class="sticky top-0 z-50 bg-bg-page/80 backdrop-blur-md border-b border-border-subtle transition-all duration-300"
>
  <div class="max-w-layout mx-auto px-md md:px-2xl flex items-center justify-between transition-all duration-300 h-20" id="header-container">
    <a href="/" class="inline-flex items-center hover:opacity-80 transition-opacity" aria-label="BSGroup — Startseite">
      <img
        src="/logos/bsg/logo-bsg-smooth.png"
        alt="BSGroup"
        class="h-7 md:h-8 w-auto transition-all duration-300"
        id="header-logo"
      />
    </a>

    <nav class="hidden lg:flex items-center gap-lg">
      {navItems.map(item => (
        item.children ? (
          <div class="relative group">
            <a
              href={item.href}
              class="flex items-center gap-1 text-body-m font-medium text-fg-primary hover:text-fg-brand transition-colors py-2xs"
              aria-haspopup="true"
            >
              {item.label}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-hover:rotate-180">
                <polyline points="3 5 6 8 9 5" />
              </svg>
            </a>
            <div class="absolute top-full left-0 pt-2 invisible group-hover:visible group-focus-within:visible opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity duration-150 z-50">
              <div class="min-w-[260px] bg-bg-page border border-border-subtle rounded-lg shadow-lg p-2xs">
                {item.children.map(child => (
                  <a
                    href={child.href}
                    class="block px-md py-xs text-body-m font-medium text-fg-primary hover:bg-bg-surface-subtle hover:text-fg-brand rounded transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a href={item.href} class="text-body-m font-medium text-fg-primary hover:text-fg-brand transition-colors">
            {item.label}
          </a>
        )
      ))}
    </nav>

    <a href="/kontakt" class="hidden lg:inline-flex items-center gap-2xs bg-bg-brand text-fg-on-brand px-md py-2xs rounded font-semibold hover:bg-bg-brand-hover transition-colors">
      Kontakt
    </a>
    <button
      id="mobile-menu-toggle"
      class="lg:hidden text-fg-primary"
      aria-label="Menü öffnen"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <svg id="mobile-menu-icon-open"  width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="6" x2="20" y2="6" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="18" x2="20" y2="18" />
      </svg>
      <svg id="mobile-menu-icon-close" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-border-subtle bg-bg-page backdrop-blur-xl">
    <nav class="max-w-layout mx-auto px-md py-md flex flex-col gap-2xs">
      {navItems.map(item => (
        item.children ? (
          <details class="group/details">
            <summary class="list-none flex items-center justify-between cursor-pointer text-body-l font-medium text-fg-primary hover:text-fg-brand transition-colors py-2xs">
              <span>{item.label}</span>
              <svg width="14" height="14" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform group-open/details:rotate-180">
                <polyline points="3 5 6 8 9 5" />
              </svg>
            </summary>
            <div class="pl-md py-xs flex flex-col gap-2xs border-l border-border-subtle ml-2xs mt-2xs">
              {item.children.map(child => (
                <a
                  href={child.href}
                  class="block text-body-m font-medium text-fg-secondary hover:text-fg-brand transition-colors py-2xs"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a href={item.href} class="block text-body-l font-medium text-fg-primary hover:text-fg-brand transition-colors py-2xs">
            {item.label}
          </a>
        )
      ))}
      <a
        href="/kontakt"
        class="mt-xs inline-flex items-center justify-center gap-2xs bg-bg-brand text-fg-on-brand px-md py-sm rounded font-semibold hover:bg-bg-brand-hover transition-colors"
      >
        Kontakt
      </a>
    </nav>
  </div>
</header>

<style>
  /* Hide native disclosure marker on <summary> */
  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }
</style>

<script>
  const setup = () => {
    // Mobile Menu Logic
    const btn = document.getElementById('mobile-menu-toggle');
    if (!btn || btn.dataset.wired === 'true') return;

    const menu  = document.getElementById('mobile-menu');
    const open  = document.getElementById('mobile-menu-icon-open');
    const close = document.getElementById('mobile-menu-icon-close');
    if (!menu || !open || !close) return;

    btn.dataset.wired = 'true';

    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const next = !expanded;
      btn.setAttribute('aria-expanded', String(next));
      btn.setAttribute('aria-label', next ? 'Menü schliessen' : 'Menü öffnen');
      menu.classList.toggle('hidden', !next);
      open.classList.toggle('hidden',  next);
      close.classList.toggle('hidden', !next);
    });

    // Shrink Header Logic
    const headerContainer = document.getElementById('header-container');
    const logo = document.getElementById('header-logo');

    const handleScroll = () => {
      if (window.scrollY > 50) {
        headerContainer?.classList.replace('h-20', 'h-14');
        logo?.classList.add('scale-90');
      } else {
        headerContainer?.classList.replace('h-14', 'h-20');
        logo?.classList.remove('scale-90');
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // Initial check
  };

  setup();
  document.addEventListener('astro:page-load', setup);
</script>
