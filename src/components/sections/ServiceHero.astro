---
interface Props {
  eyebrow: string;
  headline: string;
  sub: string;
  ctaLabel: string;
  ctaHref: string;
  image: string;
  imagePosition?: string;
}
const { eyebrow, headline, sub, ctaLabel, ctaHref, image, imagePosition = 'center' } = Astro.props;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0">
    <img
      src={image}
      alt=""
      class="h-full w-full object-cover"
      style={`object-position: ${imagePosition};`}
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to right, rgb(0 23 137 / 0.85) 0%, rgb(0 23 137 / 0.4) 55%, rgb(0 23 137 / 0.1) 100%);"
    ></div>
  </div>

  <div class="relative max-w-layout mx-auto px-md md:px-2xl py-3xl md:py-5xl flex flex-col justify-end min-h-[480px] md:min-h-[560px]">
    <div class="max-w-2xl text-white space-y-md">
      <p class="text-eyebrow text-white/90">{eyebrow.toUpperCase()}</p>
      <h1 class="text-4xl md:text-display-l font-bold tracking-tight">{headline}</h1>
      <p class="text-body-l text-white/85">{sub}</p>
      <div class="pt-sm">
        <a
          href={ctaHref}
          class="inline-flex items-center gap-2xs bg-white text-fg-brand px-lg py-sm rounded font-semibold hover:bg-bg-brand-subtle transition-colors"
        >
          {ctaLabel} <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
