---
import type { Case } from '@/data/cases';

interface Props {
  case: Case;
  heading?: string;
}
const { case: c, heading = 'Eine Referenz dazu.' } = Astro.props;
---

<section class="bg-bg-surface-subtle">
  <div class="max-w-layout mx-auto px-md md:px-2xl py-3xl md:py-4xl space-y-2xl">
    <h2 class="text-4xl md:text-display-l font-bold text-fg-primary">{heading}</h2>
    <a
      href={c.href}
      class="group flex flex-col gap-sm max-w-md rounded-lg border border-border-subtle bg-bg-surface p-lg transition-shadow hover:shadow-md"
    >
      <span class="self-start rounded-full bg-bg-brand-subtle px-xs py-[4px] text-eyebrow text-fg-brand">
        {c.industry}
      </span>
      <h3 class="text-h3 font-semibold text-fg-primary">{c.headline}</h3>
      <p class="text-body-m text-fg-secondary">{c.outcome}</p>
      <p class="text-body-s text-fg-muted">{c.platform} · {c.serviceLine}</p>
      <p class="inline-flex items-center gap-2xs text-body-m font-medium text-fg-brand pt-2xs">
        Mehr lesen <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
      </p>
    </a>
  </div>
</section>
