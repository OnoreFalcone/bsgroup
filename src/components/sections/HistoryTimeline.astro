---
import { milestones } from '@/data/milestones';
const N = milestones.length;
---

<section class="bg-bg-page overflow-hidden">
  <div class="max-w-layout mx-auto px-md md:px-2xl py-3xl md:py-5xl">
    <div class="space-y-md max-w-2xl mb-2xl reveal-fade-in">
      <p class="text-eyebrow text-fg-brand">30 JAHRE</p>
      <h2 class="text-4xl md:text-display-l font-bold text-fg-primary">Eine Linie. Neun Momente.</h2>
      <p class="text-body-l text-fg-secondary">
        Was wir seit 1995 für den Schweizer Finanzplatz geliefert haben — auf einer Zeitachse zusammengefasst.
      </p>
    </div>

    {/* Mobile/Tablet: Zig-Zag Vertical (Option 2) */}
    <div class="lg:hidden relative py-xl">
      {/* Central Vertical Line */}
      <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-1 bg-bg-brand/10 rounded-full"></div>
      <div 
        id="timeline-vertical-progress"
        class="absolute left-1/2 -translate-x-1/2 top-0 w-1 bg-bg-brand rounded-full transition-all duration-[2000ms] origin-top scale-y-0"
        style="bottom: 0;"
      ></div>

      <div class="space-y-12 relative">
        {milestones.map((m, idx) => {
          const isEven = idx % 2 === 0;
          return (
            <div class:list={[
              'flex items-center w-full timeline-item-vertical transition-all duration-700 opacity-0 translate-y-8',
              isEven ? 'flex-row' : 'flex-row-reverse'
            ]}>
              {/* Text Side */}
              <div class:list={['w-1/2 px-sm sm:px-md', isEven ? 'text-right' : 'text-left']}>
                <p class:list={['text-2xl font-bold leading-none', m.isCurrent ? 'text-fg-brand' : 'text-fg-primary']}>
                  {m.year}
                </p>
                <p class="text-[10px] text-fg-muted uppercase tracking-widest mt-1 mb-xs">{m.tag}</p>
                <h3 class="text-body-m font-semibold text-fg-primary leading-tight">{m.head}</h3>
                <p class="text-[11px] text-fg-secondary leading-snug mt-1">{m.body}</p>
              </div>

              {/* Center Node */}
              <div class="relative z-10 flex-shrink-0">
                <div class:list={[
                  'w-4 h-4 rounded-full border-2 border-white bg-bg-brand shadow-md',
                  m.isCurrent && 'ring-4 ring-bg-brand-subtle scale-125 pulse-ring'
                ]}></div>
              </div>

              {/* Empty Side for Balance */}
              <div class="w-1/2"></div>
            </div>
          );
        })}
      </div>
    </div>

    {/* Desktop: Horizontal (At a glance) */}
    <div class="hidden lg:block relative mt-4xl">
      {/* Background Track Line */}
      <div class="absolute left-0 right-0 h-1 bg-bg-brand/10 top-1/2 -translate-y-1/2 rounded-full"></div>
      
      {/* Animated Progress Line */}
      <div 
        id="timeline-progress"
        class="absolute left-0 h-1 bg-bg-brand top-1/2 -translate-y-1/2 rounded-full transition-all duration-[2000ms] ease-out origin-left scale-x-0"
        style="right: 0;"
      ></div>

      <div class="grid relative min-h-[520px]" style={`grid-template-columns: repeat(${N}, minmax(0, 1fr));`}>
        {milestones.map((m, idx) => {
          const isEven = idx % 2 === 0;
          return (
            <div class="relative group h-full flex flex-col items-center timeline-group">
              <div class:list={[
                'absolute w-[130px] xl:w-[220px] px-2xs xl:px-sm transition-all duration-700 timeline-card opacity-0 translate-y-8',
                isEven ? 'bottom-[calc(50%+40px)]' : 'top-[calc(50%+40px)]'
              ]}>
                <div class="text-center space-y-2xs">
                  <p class:list={['text-2xl xl:text-4xl font-bold leading-none transition-colors duration-300', m.isCurrent ? 'text-fg-brand' : 'text-fg-primary group-hover:text-fg-brand']}>
                    {m.year}
                  </p>
                  <p class="text-[10px] xl:text-eyebrow text-fg-muted uppercase tracking-wider">{m.tag}</p>
                  <div class="pt-xs space-y-2xs">
                    <h3 class="text-body-m xl:text-h4 font-semibold text-fg-primary leading-tight">{m.head}</h3>
                    <p class="text-[11px] xl:text-body-s text-fg-secondary leading-snug">{m.body}</p>
                  </div>
                </div>
              </div>

              <div class="absolute top-1/2 -translate-y-1/2 z-20">
                <div class:list={[
                  'w-5 h-5 rounded-full border-4 border-white bg-bg-brand transition-all duration-500 shadow-md group-hover:scale-150 group-hover:shadow-lg',
                  m.isCurrent ? 'ring-8 ring-bg-brand-subtle scale-125 pulse-ring' : ''
                ]}></div>
                
                <div class:list={[
                  'absolute left-1/2 -translate-x-1/2 w-px bg-bg-brand/30 transition-all duration-1000 h-0 timeline-connector',
                  isEven ? 'bottom-full mb-1' : 'top-full mt-1'
                ]}></div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<style>
  .pulse-ring {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(0, 23, 137, 0.4); }
    70% { box-shadow: 0 0 0 15px rgba(0, 23, 137, 0); }
    100% { box-shadow: 0 0 0 0 rgba(0, 23, 137, 0); }
  }

  /* Entrance Animations */
  .timeline-card, 
  .timeline-item-vertical {
    opacity: 0;
    transform: translateY(2rem);
    transition: opacity 700ms ease-out, transform 700ms ease-out;
  }

  .timeline-group.is-visible .timeline-card, 
  .timeline-item-vertical.is-visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  .timeline-connector {
    transition: height 1000ms ease-out;
  }

  .timeline-group.is-visible .timeline-connector {
    height: 48px;
  }

  .reveal-fade-in { 
    opacity: 0; 
    transition: opacity 800ms ease-out; 
  }
  
  :global(.is-section-visible) .reveal-fade-in { 
    opacity: 1; 
  }
</style>

<script>
  const setup = () => {
    const sectionObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-section-visible');
          
          // Animate Horizontal Line
          const progressLine = entry.target.querySelector('#timeline-progress') as HTMLElement;
          if (progressLine) progressLine.style.transform = 'scaleX(1)';

          // Animate Vertical Line
          const verticalLine = entry.target.querySelector('#timeline-vertical-progress') as HTMLElement;
          if (verticalLine) verticalLine.style.transform = 'scaleY(1)';

          // Stagger Horizontal Items
          const groups = entry.target.querySelectorAll('.timeline-group');
          groups.forEach((group, i) => {
            setTimeout(() => group.classList.add('is-visible'), i * 150);
          });

          // Stagger Vertical Items
          const verticalItems = entry.target.querySelectorAll('.timeline-item-vertical');
          verticalItems.forEach((item, i) => {
            setTimeout(() => item.classList.add('is-visible'), i * 150);
          });
          
          sectionObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    const timelineSection = document.querySelector('section.overflow-hidden');
    if (timelineSection) sectionObserver.observe(timelineSection);
  };

  setup();
  document.addEventListener('astro:page-load', setup);
</script>
