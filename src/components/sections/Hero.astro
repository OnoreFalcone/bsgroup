---
import { withBase } from '@/utils/url';

interface Props {
  eyebrow?: string;
  headline?: string;
  subline?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  eyebrow = 'SCHWEIZER FINANZPLATZ · SEIT 1995',
  headline = 'Aus Konzept wird Realität.',
  subline = 'Wir bringen Ihre Projekte ins Ziel — pragmatisch, erfahren und verbindlich. Seit über 30 Jahren.',
  primaryLabel = 'Projekt besprechen',
  primaryHref = withBase('/kontakt'),
  secondaryLabel = 'Referenzen ansehen',
  secondaryHref = withBase('/referenzen'),
} = Astro.props;

const heroBg = withBase('/images/scenery/shutterstock_1947194422-scaled.jpg');
---

<section class="relative overflow-hidden group">
  <div class="absolute inset-0">
    <img
      src={heroBg}
      alt=""
      class="h-full w-full object-cover transition-transform duration-[10000ms] ease-out group-hover:scale-110"
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to right, rgb(0 23 137 / 0.85) 0%, rgb(0 23 137 / 0.4) 55%, rgb(0 23 137 / 0.1) 100%);"
    ></div>
  </div>

  <div class="relative max-w-layout mx-auto px-md md:px-2xl py-3xl md:py-5xl flex flex-col justify-end min-h-[640px] md:min-h-[720px]">
    <div class="max-w-2xl text-white space-y-md">
      <p class="text-eyebrow text-white/90">{eyebrow}</p>
      <h1 class="text-5xl md:text-display-l font-bold tracking-tight">
        {headline}
      </h1>
      <p class="text-body-l text-white/85 max-w-prose">
        {subline}
      </p>
      <div class="flex flex-wrap gap-sm pt-sm">
        <a
          href={primaryHref}
          class="inline-flex items-center gap-2xs bg-white text-fg-brand px-lg py-sm rounded font-semibold hover:bg-bg-brand-subtle transition-colors"
        >
          {primaryLabel} <span aria-hidden="true">→</span>
        </a>
        <a
          href={secondaryHref}
          class="inline-flex items-center gap-2xs border border-white text-white px-lg py-sm rounded font-semibold hover:bg-white/10 transition-colors"
        >
          {secondaryLabel} <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
