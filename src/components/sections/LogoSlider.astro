---
import { sliderLogos } from '@/data/site';
import { withBase } from '@/utils/url';
// Triplicating the set to ensure absolutely seamless looping on all screen widths
const track = [...sliderLogos, ...sliderLogos, ...sliderLogos];
---

<section class="bg-bg-surface-subtle py-lg overflow-hidden border-y border-border-subtle">
  <div class="flex w-max animate-marquee items-center">
    {track.map((logo, index) => (
      <img
        src={withBase(`/logos/clients/${logo.filename}`)}
        alt={logo.alt}
        class="h-10 md:h-12 w-auto object-contain shrink-0 mx-xl md:mx-2xl"
        loading="lazy"
        aria-hidden={index >= sliderLogos.length ? 'true' : undefined}
      />
    ))}
  </div>
</section>

<style>
  @keyframes marquee-infinite {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-100% / 3)); }
  }

  .animate-marquee {
    animation: marquee-infinite 30s linear infinite;
  }

  /* Pause on hover for better UX */
  .animate-marquee:hover {
    animation-play-state: paused;
  }

  /* Respect reduced-motion preference */
  @media (prefers-reduced-motion: reduce) {
    .animate-marquee {
      animation: none;
    }
  }
</style>
