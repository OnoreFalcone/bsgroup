---
interface Props {
  heading: string;
  paragraphs: string[];
}
const { heading, paragraphs } = Astro.props;
---

<section class="bg-bg-page">
  <div class="max-w-layout mx-auto px-md md:px-2xl py-3xl md:py-4xl">
    <div class="max-w-prose space-y-md">
      <h2 class="text-3xl md:text-h1 font-semibold text-fg-primary">{heading}</h2>
      {paragraphs.map(p => (
        <p class="text-body-l text-fg-secondary">{p}</p>
      ))}
    </div>
  </div>
</section>
