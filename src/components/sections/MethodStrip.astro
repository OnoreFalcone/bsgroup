---
import type { ServiceStep } from '@/data/services';

interface Props {
  steps: ServiceStep[];
  heading?: string;
}
const { steps, heading = 'Unsere Methode.' } = Astro.props;
---

<section class="bg-bg-page">
  <div class="max-w-layout mx-auto px-md md:px-2xl py-3xl md:py-4xl space-y-2xl">
    <h2 class="text-4xl md:text-display-l font-bold text-fg-primary">{heading}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-lg">
      {steps.map((step, i) => (
        <div class="space-y-xs">
          <p class="text-eyebrow text-fg-brand">SCHRITT {String(i + 1).padStart(2, '0')}</p>
          <h3 class="text-h3 font-semibold text-fg-primary">{step.name}</h3>
          <p class="text-body-m text-fg-secondary">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
