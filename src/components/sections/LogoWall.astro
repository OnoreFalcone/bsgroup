---
import { sliderLogos } from '@/data/site';
---

<section class="bg-bg-surface-subtle">
  <div class="max-w-layout mx-auto px-md md:px-2xl py-3xl md:py-4xl space-y-2xl">
    <div class="flex flex-wrap items-center justify-center gap-x-2xl gap-y-md">
      {sliderLogos.map(logo => (
        <img
          src={`/logos/clients/${logo.filename}`}
          alt={logo.alt}
          class="h-12 w-auto object-contain"
          loading="lazy"
        />
      ))}
    </div>
    <p class="max-w-3xl mx-auto text-center text-body-m text-fg-secondary">
      Wir haben für 4 Schweizer Privatbanken, 3 Kantonalbanken, 6 Krankenversicherer, 5 Versicherer und 8 weitere Finanzdienstleister gearbeitet. Eine vollständige Referenzliste teilen wir auf Anfrage unter NDA.
    </p>
  </div>
</section>
